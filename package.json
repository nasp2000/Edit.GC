{
  "name": "edit.gc",
  "version": "1.0.0",
  "description": "A browser-based G-code editor for laser and CNC. Edit lines and points, convert SVG/DXF to toolpaths, and visualize G-code — all local, no installation or server required.",
  "main": "index.js",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "test": "node test/unit.js",
    "test:integration": "node test/runner.js",
    "test:markstart": "node test/markstart.test.js",
    "test:all": "node test/unit.js && node test/runner.js && node test/markstart.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nasp2000/Edit.GC.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nasp2000/Edit.GC/issues"
  },
  "homepage": "https://github.com/nasp2000/Edit.GC#readme",
  "dependencies": {
    "puppeteer": "^25.3.0"
  },
  "allowScripts": {
    "puppeteer@25.3.0": true
  }
}
